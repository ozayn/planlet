# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# Google OAuth credentials (https://console.cloud.google.com/)
AUTH_GOOGLE_ID=replace-me
AUTH_GOOGLE_SECRET=replace-me

# App URL — required in production (e.g. https://your-app.up.railway.app)
# Auth.js v5 may also read AUTH_URL; this project uses NEXTAUTH_URL.
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Comma-separated Google emails allowed to sign in (case-insensitive).
# Leave empty locally to allow any Google account; set in production to lock the app.
ALLOWED_EMAILS=your-email@example.com,friend@example.com

# Comma-separated admin emails (always allowed to sign in; get ADMIN role).
PLANLET_ADMIN_EMAILS=your-email@example.com

# Text plan parser provider: openai (default) or anthropic
PLANLET_AI_PROVIDER=openai

# OpenAI — required for audio transcription; required for text parsing when PLANLET_AI_PROVIDER=openai
OPENAI_API_KEY=

# OpenAI transcription model (optional, defaults to gpt-4o-mini-transcribe)
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# OpenAI vision model for notebook image text extraction (optional, defaults to gpt-4o-mini)
OPENAI_VISION_MODEL=gpt-4o-mini

# Anthropic — required for text parsing when PLANLET_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Anthropic model for text parsing (optional, defaults to claude-sonnet-4-5)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Web Push (optional) — generate VAPID keys with: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:your-email@example.com
