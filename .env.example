# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# Google OAuth credentials (https://console.cloud.google.com/)
AUTH_GOOGLE_ID=replace-me
AUTH_GOOGLE_SECRET=replace-me

# App URL — required in production (e.g. https://your-app.up.railway.app)
# Auth.js v5 may also read AUTH_URL; this project uses NEXTAUTH_URL.
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Comma-separated Google emails allowed to sign in (case-insensitive).
# Leave empty locally to allow any Google account; set in production to lock the app.
ALLOWED_EMAILS=your-email@example.com,friend@example.com

# Comma-separated admin emails (always allowed to sign in; get ADMIN role + all capabilities).
PLANLET_ADMIN_EMAILS=your-email@example.com

# Comma-separated reflector emails (canUseReflectionFeatures: private observations + gratitude).
PLANLET_REFLECTOR_EMAILS=your-email@example.com

# Comma-separated feedback emails (canGiveFeedback: in-app product feedback).
PLANLET_FEEDBACK_EMAILS=your-email@example.com,friend@example.com

# Comma-separated coach emails (canUseCoachingFeatures: AI reflection lens).
PLANLET_COACH_EMAILS=your-email@example.com

# Comma-separated job tracker emails (canUseJobTrackerFeatures: private job applications).
PLANLET_JOB_TRACKER_EMAILS=your-email@example.com

# Comma-separated career journey emails (canUseCareerJourneyFeatures: gentle career structure).
PLANLET_CAREER_JOURNEY_EMAILS=your-email@example.com

# Comma-separated body journey emails (canUseBodyJourneyFeatures: private body sensation tracking).
BODY_JOURNEY_EMAILS=your-email@example.com

# Body Journey dev overlay: faint region outlines and coordinate grid on /body (default off).
NEXT_PUBLIC_SHOW_BODY_GUIDES=false

# Text plan parser provider: openai (default) or anthropic
PLANLET_AI_PROVIDER=openai

# OpenAI — required for audio transcription; required for text parsing when PLANLET_AI_PROVIDER=openai
OPENAI_API_KEY=

# OpenAI transcription model (optional, defaults to gpt-4o-mini-transcribe)
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# OpenAI vision model for notebook image text extraction (optional, defaults to gpt-4o-mini)
OPENAI_VISION_MODEL=gpt-4o-mini

# Anthropic — required for text parsing when PLANLET_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Anthropic model for text parsing (optional, defaults to claude-sonnet-4-5)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Web Push (optional) — generate VAPID keys with: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:your-email@example.com

# Cron secret for scheduled reminder dispatch (optional until reminders are enabled in production)
CRON_SECRET=

# Stripe support link (optional) — shown in avatar menu as "Support Planlet"
NEXT_PUBLIC_STRIPE_SUPPORT_URL=
