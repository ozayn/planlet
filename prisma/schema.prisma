generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  DAY
  WEEK
  MONTH
  YEAR
}

enum PlanLanguage {
  FA
  EN
  MIXED
  UNKNOWN
}

enum PlanItemType {
  TASK
  EVENT
  INTENTION
  NOTE
  WORK_BLOCK
  ERRAND
  SOCIAL
  REST
}

enum PlanItemStatus {
  OPEN
  DONE
  PARTIAL
  NOT_DONE
  MOVED
  SKIPPED
  RELEASED
}

enum SatisfactionLevel {
  LOW
  OKAY
  SATISFIED
  PROUD
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
  CERTAIN
}

enum ExcitementLevel {
  AVOIDING
  NEUTRAL
  INTERESTED
  EXCITED
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
}

enum TimeHint {
  MORNING
  AFTERNOON
  EVENING
  ANYTIME
  ALL_DAY
  SPECIFIC
}

enum ShareExportFormat {
  PLAIN_TEXT
  TELEGRAM
  SUMMARY
}

enum UserRole {
  USER
  REFLECTOR
  ADMIN
}

enum PlanSharePermission {
  VIEW
}

enum NotificationType {
  PLAN_SHARED
  PLAN_KUDOS
  PLAN_ITEM_COMMENT
  APP_FEEDBACK
}

enum FeedbackArea {
  MOBILE
  UI
  TASKS
  PLANS
  INSIGHTS
  SHARING
  NOTIFICATIONS
  SETTINGS
  ADMIN
  AI_IMPORT
  OTHER
}

enum FeedbackStatus {
  OPEN
  REVIEWED
  PLANNED
  DONE
  WONT_DO
}

enum FeedbackPriority {
  LOW
  NORMAL
  HIGH
}

enum KudosType {
  CHEER
  PROUD
  ROOTING
  WARMTH
}

enum PlanItemView {
  MINIMAL
  CHECKLIST
}

enum ObservationCategory {
  MIND
  EMOTION
  BODY
  SLEEP
  ENERGY
  CYCLE
  PAIN
  SKIN
  SUBSTANCES
  OTHER
}

enum ReminderType {
  MORNING_PLAN
  EVENING_REFLECTION
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  role                      UserRole    @default(USER)
  canGiveFeedback           Boolean     @default(false)
  canUseReflectionFeatures  Boolean     @default(false)
  planItemView              PlanItemView @default(CHECKLIST)
  lastSeenAt    DateTime?
  lastLoginAt   DateTime?
  loginCount    Int         @default(0)
  accounts      Account[]
  sessions      Session[]
  plans         Plan[]
  themes        Theme[]
  planSharesOwned    PlanShare[] @relation("PlanShareOwner")
  planSharesReceived PlanShare[] @relation("PlanShareRecipient")
  sentKudos          PlanKudos[] @relation("SentKudos")
  receivedKudos      PlanKudos[] @relation("ReceivedKudos")
  notifications      Notification[]
  pushSubscriptions        PushSubscription[]
  notificationPreference   NotificationPreference?
  sentReminders            SentReminder[]
  planItemComments         PlanItemComment[]
  observations       PlanObservation[]
  gratitudes         PlanGratitude[]
  therapyThoughts    TherapyThought[]
  feedbackItems      AppFeedback[] @relation("AuthoredFeedback")
  resolvedFeedback   AppFeedback[] @relation("ResolvedFeedback")
  loginEvents   LoginEvent[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model NotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  morningEnabled Boolean  @default(false)
  morningTime    String   @default("09:00")
  eveningEnabled Boolean  @default(false)
  eveningTime    String   @default("21:00")
  timezone       String   @default("America/New_York")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SentReminder {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReminderType
  localDate String
  sentAt    DateTime     @default(now())

  @@unique([userId, type, localDate])
  @@index([userId, localDate])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  provider  String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Plan {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         PlanType
  title        String
  dateStart    DateTime
  dateEnd      DateTime
  rawInput     String?
  summary      String?
  language     PlanLanguage   @default(UNKNOWN)
  items        PlanItem[]
  shareExports ShareExport[]
  shares       PlanShare[]
  kudos        PlanKudos[]
  observations PlanObservation[]
  gratitudes   PlanGratitude[]
  therapyThoughts TherapyThought[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId, type, dateStart])
}

model AppFeedback {
  id           String           @id @default(cuid())
  authorId     String
  author       User             @relation("AuthoredFeedback", fields: [authorId], references: [id], onDelete: Cascade)
  area         FeedbackArea
  pagePath     String?
  title        String?
  body         String           @db.Text
  status       FeedbackStatus   @default(OPEN)
  priority     FeedbackPriority @default(NORMAL)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?            @relation("ResolvedFeedback", fields: [resolvedById], references: [id])

  @@index([authorId, createdAt])
  @@index([status, createdAt])
  @@index([area, createdAt])
}

model PlanGratitude {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId, createdAt])
  @@index([userId, createdAt])
}

model TherapyThought {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([planId, createdAt])
}

model PlanObservation {
  id         String              @id @default(cuid())
  planId     String
  plan       Plan                @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   ObservationCategory
  body       String              @db.Text
  observedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([planId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, category, createdAt])
}

model PlanKudos {
  id          String    @id @default(cuid())
  planId      String
  plan        Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User      @relation("SentKudos", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User      @relation("ReceivedKudos", fields: [recipientId], references: [id], onDelete: Cascade)
  type        KudosType
  message     String?
  createdAt   DateTime  @default(now())

  @@unique([planId, senderId])
  @@index([planId])
  @@index([senderId])
  @@index([recipientId])
  @@index([createdAt])
}

model PlanShare {
  id               String              @id @default(cuid())
  planId           String
  plan             Plan                @relation(fields: [planId], references: [id], onDelete: Cascade)
  ownerId          String
  owner            User                @relation("PlanShareOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  sharedWithUserId String
  sharedWithUser   User                @relation("PlanShareRecipient", fields: [sharedWithUserId], references: [id], onDelete: Cascade)
  permission       PlanSharePermission @default(VIEW)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([planId, sharedWithUserId])
  @@index([ownerId])
  @@index([sharedWithUserId])
  @@index([planId])
}

model PlanItem {
  id                String             @id @default(cuid())
  planId            String
  plan              Plan               @relation(fields: [planId], references: [id], onDelete: Cascade)
  parentItemId      String?
  parentItem        PlanItem?          @relation("PlanItemSubtasks", fields: [parentItemId], references: [id], onDelete: Cascade)
  subtasks          PlanItem[]         @relation("PlanItemSubtasks")
  title             String
  description       String?
  type              PlanItemType       @default(TASK)
  status            PlanItemStatus     @default(OPEN)
  progressLevel     Int                @default(0)
  satisfactionLevel SatisfactionLevel?
  confidenceLevel   ConfidenceLevel?
  excitementLevel   ExcitementLevel?
  importance        PriorityLevel?
  urgency           PriorityLevel?
  timeHint          TimeHint?
  startTime         DateTime?
  endTime           DateTime?
  durationMinutes   Int?
  comment           String?
  shareable         Boolean            @default(true)
  sortOrder         Int                @default(0)
  themes            PlanItemTheme[]
  comments          PlanItemComment[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([planId, sortOrder])
  @@index([parentItemId])
}

model PlanItemComment {
  id        String   @id @default(cuid())
  itemId    String
  item      PlanItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId, createdAt])
  @@index([authorId, createdAt])
}

model Theme {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  active      Boolean         @default(true)
  items       PlanItemTheme[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId, name])
}

model PlanItemTheme {
  id         String   @id @default(cuid())
  planItemId String
  planItem   PlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)
  themeId    String
  theme      Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([planItemId, themeId])
}

model ShareExport {
  id        String            @id @default(cuid())
  planId    String
  plan      Plan              @relation(fields: [planId], references: [id], onDelete: Cascade)
  format    ShareExportFormat
  content   String            @db.Text
  createdAt DateTime          @default(now())

  @@index([planId, createdAt])
}
