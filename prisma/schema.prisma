generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  DAY
  WEEK
  MONTH
  YEAR
}

enum PlanLanguage {
  FA
  EN
  MIXED
  UNKNOWN
}

enum PlanItemType {
  TASK
  EVENT
  INTENTION
  NOTE
  WORK_BLOCK
  ERRAND
  SOCIAL
  REST
}

enum PlanItemStatus {
  OPEN
  DONE
  PARTIAL
  MOVED
  SKIPPED
  RELEASED
}

enum SatisfactionLevel {
  LOW
  OKAY
  SATISFIED
  PROUD
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
  CERTAIN
}

enum ExcitementLevel {
  AVOIDING
  NEUTRAL
  INTERESTED
  EXCITED
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
}

enum TimeHint {
  MORNING
  AFTERNOON
  EVENING
  ANYTIME
  ALL_DAY
  SPECIFIC
}

enum ShareExportFormat {
  PLAIN_TEXT
  TELEGRAM
  SUMMARY
}

enum UserRole {
  USER
  ADMIN
}

enum PlanSharePermission {
  VIEW
}

enum NotificationType {
  PLAN_SHARED
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  role          UserRole    @default(USER)
  lastLoginAt   DateTime?
  loginCount    Int         @default(0)
  accounts      Account[]
  sessions      Session[]
  plans         Plan[]
  themes        Theme[]
  planSharesOwned    PlanShare[] @relation("PlanShareOwner")
  planSharesReceived PlanShare[] @relation("PlanShareRecipient")
  notifications      Notification[]
  loginEvents   LoginEvent[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  provider  String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Plan {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         PlanType
  title        String
  dateStart    DateTime
  dateEnd      DateTime
  rawInput     String?
  summary      String?
  language     PlanLanguage   @default(UNKNOWN)
  items        PlanItem[]
  shareExports ShareExport[]
  shares       PlanShare[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId, type, dateStart])
}

model PlanShare {
  id               String              @id @default(cuid())
  planId           String
  plan             Plan                @relation(fields: [planId], references: [id], onDelete: Cascade)
  ownerId          String
  owner            User                @relation("PlanShareOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  sharedWithUserId String
  sharedWithUser   User                @relation("PlanShareRecipient", fields: [sharedWithUserId], references: [id], onDelete: Cascade)
  permission       PlanSharePermission @default(VIEW)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([planId, sharedWithUserId])
  @@index([ownerId])
  @@index([sharedWithUserId])
  @@index([planId])
}

model PlanItem {
  id                String             @id @default(cuid())
  planId            String
  plan              Plan               @relation(fields: [planId], references: [id], onDelete: Cascade)
  parentItemId      String?
  parentItem        PlanItem?          @relation("PlanItemSubtasks", fields: [parentItemId], references: [id], onDelete: Cascade)
  subtasks          PlanItem[]         @relation("PlanItemSubtasks")
  title             String
  description       String?
  type              PlanItemType       @default(TASK)
  status            PlanItemStatus     @default(OPEN)
  progressLevel     Int                @default(0)
  satisfactionLevel SatisfactionLevel?
  confidenceLevel   ConfidenceLevel?
  excitementLevel   ExcitementLevel?
  importance        PriorityLevel?
  urgency           PriorityLevel?
  timeHint          TimeHint?
  startTime         DateTime?
  endTime           DateTime?
  durationMinutes   Int?
  comment           String?
  shareable         Boolean            @default(true)
  sortOrder         Int                @default(0)
  themes            PlanItemTheme[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([planId, sortOrder])
  @@index([parentItemId])
}

model Theme {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  active      Boolean         @default(true)
  items       PlanItemTheme[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId, name])
}

model PlanItemTheme {
  id         String   @id @default(cuid())
  planItemId String
  planItem   PlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)
  themeId    String
  theme      Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([planItemId, themeId])
}

model ShareExport {
  id        String            @id @default(cuid())
  planId    String
  plan      Plan              @relation(fields: [planId], references: [id], onDelete: Cascade)
  format    ShareExportFormat
  content   String            @db.Text
  createdAt DateTime          @default(now())

  @@index([planId, createdAt])
}
