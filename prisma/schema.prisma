generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  DAY
  WEEK
  MONTH
  YEAR
}

enum PlanLanguage {
  FA
  EN
  MIXED
  UNKNOWN
}

enum PlanItemType {
  TASK
  EVENT
  INTENTION
  NOTE
  WORK_BLOCK
  ERRAND
  SOCIAL
  REST
}

enum PlanItemStatus {
  OPEN
  DONE
  PARTIAL
  NOT_DONE
  MOVED
  SKIPPED
  RELEASED
}

enum SatisfactionLevel {
  LOW
  OKAY
  SATISFIED
  PROUD
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
  CERTAIN
}

enum ExcitementLevel {
  AVOIDING
  NEUTRAL
  INTERESTED
  EXCITED
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
}

enum TimeHint {
  MORNING
  AFTERNOON
  EVENING
  ANYTIME
  ALL_DAY
  SPECIFIC
}

enum ShareExportFormat {
  PLAIN_TEXT
  TELEGRAM
  SUMMARY
}

enum UserRole {
  USER
  PERSONAL
  REFLECTOR
  ADMIN
}

enum LifeLabReadAloudProvider {
  DEVICE
  OPENAI
}

enum OpenAiNarrationStyle {
  BRITISH_FEMALE_CALM
  NEUTRAL_EDUCATIONAL
  WARM_CONVERSATIONAL
  CUSTOM
}

enum CoachingOpenAiNarrationStyle {
  KIND_BRITISH_MENTOR
}

enum PlanSharePermission {
  VIEW
}

enum NotificationType {
  PLAN_SHARED
  PLAN_KUDOS
  PLAN_ITEM_COMMENT
  APP_FEEDBACK
  USER_POKE
}

enum FeedbackArea {
  MOBILE
  UI
  TASKS
  PLANS
  INSIGHTS
  SHARING
  NOTIFICATIONS
  SETTINGS
  ADMIN
  AI_IMPORT
  OTHER
}

enum FeedbackStatus {
  OPEN
  REVIEWED
  PLANNED
  DONE
  WONT_DO
}

enum FeedbackPriority {
  LOW
  NORMAL
  HIGH
}

enum KudosType {
  CHEER
  PROUD
  ROOTING
  WARMTH
}

enum PokeType {
  ENCOURAGE
  CHECK_IN
  CELEBRATE
  LEARN
  FOCUS
  PAUSE
  THINKING_OF_YOU
}

enum PlanItemView {
  MINIMAL
  CHECKLIST
}

enum ReadingDensity {
  COMPACT
  COMFORTABLE
}

enum TaskOrganizationDisplay {
  MINIMAL
  ASSIGNED_ONLY
  ALWAYS
}

enum TimezoneMode {
  AUTOMATIC
  MANUAL
}

enum ObservationCategory {
  MIND
  EMOTION
  BODY
  SLEEP
  ENERGY
  CYCLE
  PAIN
  SKIN
  SUBSTANCES
  OTHER
}

enum ReminderType {
  MORNING_PLAN
  EVENING_REFLECTION
}

enum JobApplicationStatus {
  SAVED
  APPLIED
  INTERVIEWING
  REJECTED
  OFFER
  WITHDRAWN
  ARCHIVED
}

enum BodySide {
  FRONT
  BACK
}

enum BodySymptomType {
  PAIN
  TENSION
  NUMBNESS
  TINGLING
  BURNING
  FATIGUE
  OTHER
  SKIN_SPOT
  RASH
  ITCHING
  BRUISE
  SWELLING
  CUT_WOUND
  COLOR_CHANGE
  TEXTURE_CHANGE
}

enum BodySkinChangeStatus {
  YES
  NO
  UNKNOWN
}

enum LearningSourceType {
  MUSEUM
  BOOK
  ARTICLE
  PODCAST
  YOUTUBE
  COURSE
  FRIEND
  CONVERSATION
  THERAPY
  IMPROV
  WORK
  PROJECT
  TRAVEL
  LIFE
  OTHER
}

enum LearningCategory {
  ART
  HISTORY
  PHILOSOPHY
  PSYCHOLOGY
  MACHINE_LEARNING
  DATA_ENGINEERING
  CAREER
  RELATIONSHIPS
  BODY
  CREATIVITY
  IMPROV
  MEDITATION
  POLITICS
  CULTURE
  SCIENCE
  TECHNOLOGY
  LANGUAGE
  SELF_UNDERSTANDING
  OTHER
}

enum IdeaCategory {
  PRODUCT
  BUSINESS
  CAREER
  PHOTOGRAPHY
  LEARNING
  TRAVEL
  WRITING
  PERSONAL
  CREATIVE
  RESEARCH
  OTHER
}

enum IdeaStatus {
  NEW
  THINKING
  EXPLORING
  BUILDING
  ARCHIVED
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  role                      UserRole    @default(USER)
  canGiveFeedback           Boolean     @default(false)
  canUseReflectionFeatures  Boolean     @default(false)
  canUseCoachingFeatures    Boolean     @default(false)
  canUseJobTrackerFeatures  Boolean     @default(false)
  canUseCareerJourneyFeatures Boolean   @default(false)
  canUseBodyJourneyFeatures   Boolean   @default(false)
  canUseLearningJourneyFeatures Boolean @default(false)
  canUseLifeLabFeatures       Boolean   @default(false)
  canUseIdeasFeatures         Boolean   @default(false)
  canUseActivityTimerFeatures Boolean   @default(false)
  lifeLabReadAloudProvider    LifeLabReadAloudProvider @default(DEVICE)
  lifeLabSpeechVoiceId        String?
  lifeLabSpeechRate           Float     @default(1)
  lifeLabOpenAiTtsVoice       String?
  lifeLabOpenAiNarrationStyle OpenAiNarrationStyle @default(BRITISH_FEMALE_CALM)
  lifeLabCustomNarrationInstructions String? @db.Text
  lifeLabReadAloudAutoContinue      Boolean @default(true)
  lifeLabReadAloudSectionInclusion  Json?
  coachingOpenAiTtsVoice            String?
  coachingOpenAiNarrationStyle      CoachingOpenAiNarrationStyle @default(KIND_BRITISH_MENTOR)
  planItemView              PlanItemView @default(CHECKLIST)
  readingDensity            ReadingDensity @default(COMPACT)
  taskOrganizationDisplay   TaskOrganizationDisplay @default(ASSIGNED_ONLY)
  mobileNavItems            String[]    @default([])
  timezone                  String?
  timezoneMode              TimezoneMode @default(AUTOMATIC)
  lastSeenAt    DateTime?
  lastLoginAt   DateTime?
  loginCount    Int         @default(0)
  accounts      Account[]
  sessions      Session[]
  plans         Plan[]
  themes        Theme[]
  projects      Project[]
  planSharesOwned    PlanShare[] @relation("PlanShareOwner")
  planSharesReceived PlanShare[] @relation("PlanShareRecipient")
  sentKudos          PlanKudos[] @relation("SentKudos")
  receivedKudos      PlanKudos[] @relation("ReceivedKudos")
  sentPokes          Poke[]      @relation("SentPokes")
  receivedPokes      Poke[]      @relation("ReceivedPokes")
  notifications      Notification[]
  pushSubscriptions        PushSubscription[]
  notificationPreference   NotificationPreference?
  sentReminders            SentReminder[]
  planItemComments         PlanItemComment[]
  observations       PlanObservation[]
  gratitudes         PlanGratitude[]
  therapyThoughts    TherapyThought[]
  feedbackItems      AppFeedback[] @relation("AuthoredFeedback")
  resolvedFeedback   AppFeedback[] @relation("ResolvedFeedback")
  loginEvents   LoginEvent[]
  reflectionInfluencePreference ReflectionInfluencePreference?
  jobApplications               JobApplication[]
  careerProfile                 CareerProfile?
  careerPillars                 CareerPillar[]
  careerCheckIns                CareerCheckIn[]
  careerPracticeSessions        CareerPracticeSession[]
  careerWeeklyReviews           CareerWeeklyReview[]
  bodyEntries                   BodyEntry[]
  learningEntries               LearningEntry[]
  ideas                         Idea[]
  activityTimerPresets          ActivityTimerPreset[]
  activityTimerSessions         ActivityTimerSession[]
  activityTimerSessionNotes     ActivityTimerSessionNote[]
  planItemReflections           PlanItemReflection[]
  aiUsageLogs                   AiUsageLog[]
  coachingNarrationCaches       CoachingNarrationCache[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model AiUsageLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature          String
  model            String?
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, feature])
}

model LifeLabNarrationCache {
  id                 String   @id @default(cuid())
  cacheKey           String   @unique
  driveFileId        String
  noteModifiedTime   String?
  contentHash        String
  model              String
  voice              String
  instructionVersion Int
  chunkIndex         Int
  sectionLabel       String?
  storageKey         String
  durationSeconds    Float?
  byteSize           Int?
  createdAt          DateTime @default(now())
  lastAccessedAt     DateTime @default(now())

  @@index([driveFileId, model, voice, instructionVersion])
  @@index([driveFileId, contentHash])
}

model CoachingNarrationCache {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cacheKey              String   @unique
  contentHash           String
  contentProfileVersion Int      @default(1)
  model                 String
  voice                 String
  narrationStyle        String
  instructionVersion    Int
  readAloudSectionId    String
  chunkIndex            Int
  sectionLabel          String?
  storageKey            String
  durationSeconds       Float?
  byteSize              Int?
  createdAt             DateTime @default(now())
  lastAccessedAt        DateTime @default(now())

  @@index([userId, contentHash])
  @@index([userId, model, voice, instructionVersion])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model NotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  morningEnabled Boolean  @default(false)
  morningTime    String   @default("09:00")
  eveningEnabled Boolean  @default(false)
  eveningTime    String   @default("21:00")
  timezone       String   @default("America/New_York")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SentReminder {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReminderType
  localDate String
  sentAt    DateTime     @default(now())

  @@unique([userId, type, localDate])
  @@index([userId, localDate])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
}

model Poke {
  id             String    @id @default(cuid())
  senderId       String
  sender         User      @relation("SentPokes", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId    String
  recipient      User      @relation("ReceivedPokes", fields: [recipientId], references: [id], onDelete: Cascade)
  pokeType       PokeType
  message        String?
  createdAt      DateTime  @default(now())
  seenAt         DateTime?
  acknowledgedAt DateTime?
  dismissedAt    DateTime?

  @@index([recipientId, dismissedAt, createdAt])
  @@index([recipientId, seenAt, dismissedAt])
  @@index([senderId, createdAt])
  @@index([senderId, recipientId, dismissedAt, seenAt])
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  provider  String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Plan {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         PlanType
  title        String
  dateStart    DateTime
  dateEnd      DateTime
  rawInput     String?
  summary      String?
  language     PlanLanguage   @default(UNKNOWN)
  items        PlanItem[]
  shareExports ShareExport[]
  shares       PlanShare[]
  kudos        PlanKudos[]
  observations PlanObservation[]
  gratitudes   PlanGratitude[]
  therapyThoughts TherapyThought[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId, type, dateStart])
}

model AppFeedback {
  id           String           @id @default(cuid())
  authorId     String
  author       User             @relation("AuthoredFeedback", fields: [authorId], references: [id], onDelete: Cascade)
  area         FeedbackArea
  pagePath     String?
  title        String?
  body         String           @db.Text
  status       FeedbackStatus   @default(OPEN)
  priority     FeedbackPriority @default(NORMAL)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?            @relation("ResolvedFeedback", fields: [resolvedById], references: [id])

  @@index([authorId, createdAt])
  @@index([status, createdAt])
  @@index([area, createdAt])
}

model PlanGratitude {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId, createdAt])
  @@index([userId, createdAt])
}

model TherapyThought {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([planId, createdAt])
}

model PlanObservation {
  id         String              @id @default(cuid())
  planId     String
  plan       Plan                @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   ObservationCategory
  body       String              @db.Text
  observedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([planId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, category, createdAt])
}

model PlanKudos {
  id          String    @id @default(cuid())
  planId      String
  plan        Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User      @relation("SentKudos", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User      @relation("ReceivedKudos", fields: [recipientId], references: [id], onDelete: Cascade)
  type        KudosType
  message     String?
  createdAt   DateTime  @default(now())

  @@unique([planId, senderId])
  @@index([planId])
  @@index([senderId])
  @@index([recipientId])
  @@index([createdAt])
}

model PlanShare {
  id               String              @id @default(cuid())
  planId           String
  plan             Plan                @relation(fields: [planId], references: [id], onDelete: Cascade)
  ownerId          String
  owner            User                @relation("PlanShareOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  sharedWithUserId String
  sharedWithUser   User                @relation("PlanShareRecipient", fields: [sharedWithUserId], references: [id], onDelete: Cascade)
  permission       PlanSharePermission @default(VIEW)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([planId, sharedWithUserId])
  @@index([ownerId])
  @@index([sharedWithUserId])
  @@index([planId])
}

model PlanItem {
  id                String             @id @default(cuid())
  planId            String
  plan              Plan               @relation(fields: [planId], references: [id], onDelete: Cascade)
  parentItemId      String?
  parentItem        PlanItem?          @relation("PlanItemSubtasks", fields: [parentItemId], references: [id], onDelete: Cascade)
  subtasks          PlanItem[]         @relation("PlanItemSubtasks")
  title             String
  description       String?
  type              PlanItemType       @default(TASK)
  status            PlanItemStatus     @default(OPEN)
  progressLevel     Int                @default(0)
  satisfactionLevel SatisfactionLevel?
  confidenceLevel   ConfidenceLevel?
  excitementLevel   ExcitementLevel?
  importance        PriorityLevel?
  urgency           PriorityLevel?
  timeHint          TimeHint?
  startTime         DateTime?
  endTime           DateTime?
  durationMinutes   Int?
  comment           String?
  shareable         Boolean            @default(true)
  sortOrder         Int                @default(0)
  completedAt       DateTime?
  themeId           String?
  theme             Theme?             @relation(fields: [themeId], references: [id], onDelete: SetNull)
  projectId         String?
  project           Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  comments          PlanItemComment[]
  reflections       PlanItemReflection[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([planId, sortOrder])
  @@index([parentItemId])
  @@index([themeId])
  @@index([projectId])
}

model PlanItemReflection {
  id         String   @id @default(cuid())
  planItemId String
  planItem   PlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason     String?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([planItemId, createdAt])
  @@index([userId, createdAt])
}

model Project {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  themeId    String?
  theme      Theme?     @relation(fields: [themeId], references: [id], onDelete: SetNull)
  name       String
  isArchived Boolean    @default(false)
  planItems  PlanItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId, name])
  @@index([themeId])
}

model Theme {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  color      String?
  isArchived Boolean    @default(false)
  projects   Project[]
  planItems  PlanItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId, name])
}

model PlanItemComment {
  id        String   @id @default(cuid())
  itemId    String
  item      PlanItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId, createdAt])
  @@index([authorId, createdAt])
}

model ShareExport {
  id        String            @id @default(cuid())
  planId    String
  plan      Plan              @relation(fields: [planId], references: [id], onDelete: Cascade)
  format    ShareExportFormat
  content   String            @db.Text
  createdAt DateTime          @default(now())

  @@index([planId, createdAt])
}

model ReflectionInfluencePreference {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  influences Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model JobApplication {
  id          String               @id @default(cuid())
  userId      String
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  company     String
  url         String?
  normalizedUrl String?
  description String?              @db.Text
  summary     String?              @db.Text
  source      String?
  referrer    String?
  location    String?
  salary      String?
  appliedDate String?
  status      JobApplicationStatus @default(SAVED)
  notes       String?              @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([userId, status])
  @@index([userId, updatedAt])
  @@index([userId, normalizedUrl])
}

enum CareerPracticeType {
  LEETCODE
  ML_REVIEW
  INTERVIEW_PREP
  COURSE
  SYSTEM_DESIGN
  PROJECT
  NETWORKING
  APPLICATION
  RECOVERY
}

enum CareerPracticeMode {
  TINY
  WARMUP
  MODERATE
  DEEP
}

enum CareerPracticeStatus {
  PLANNED
  DONE
  SKIPPED
  MOVED
}

model CareerProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRoles  Json
  currentFocus String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CareerPillar {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  weeklyTarget Int      @default(1)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  checkIns     CareerCheckIn[]

  @@index([userId, sortOrder])
}

model CareerCheckIn {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         String
  pillarId     String?
  pillar       CareerPillar? @relation(fields: [pillarId], references: [id], onDelete: SetNull)
  energyBefore Int?
  energyAfter  Int?
  difficulty   Int?
  note         String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId, date])
}

model CareerPracticeSession {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      CareerPracticeType
  mode      CareerPracticeMode
  title     String
  status    CareerPracticeStatus @default(PLANNED)
  date      String
  notes     String?              @db.Text
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([userId, date])
  @@index([userId, status])
}

model CareerWeeklyReview {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart     String
  gaveEnergy    String?  @db.Text
  drainedEnergy String?  @db.Text
  roleFeltAlive String?  @db.Text
  nextStep      String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}

model BodyEntry {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  observedAt  DateTime
  bodySide    BodySide
  markerX     Float
  markerY     Float
  symptomType BodySymptomType
  intensity   Int
  notes       String?          @db.Text
  tags        String[]
  skinSize    String?
  skinShape   String?
  skinColor   String?
  skinChanged BodySkinChangeStatus?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId, observedAt])
  @@index([userId, symptomType])
}

model LearningEntry {
  id         String              @id @default(cuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  summary    String              @db.Text
  sourceType LearningSourceType?
  sourceName String?
  category   LearningCategory?
  learnedAt  DateTime
  notes      String?             @db.Text
  importance Int                 @default(3)
  themes     String[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([userId, learnedAt])
}

model Idea {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String        @db.Text
  category  IdeaCategory?
  status    IdeaStatus    @default(NEW)
  tags      String[]
  notes     String?       @db.Text
  ideaDate  DateTime
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId, ideaDate])
  @@index([userId, status])
}

model ActivityTimerPreset {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                 String
  category              String?
  targetDurationSeconds Int?
  timerMode             String   @default("countUp")
  iconName              String?
  isArchived            Boolean  @default(false)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  sessions              ActivityTimerSession[]

  @@index([userId, isArchived, sortOrder])
}

model ActivityTimerSession {
  id                        String               @id @default(cuid())
  userId                    String
  user                      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  presetId                  String?
  preset                    ActivityTimerPreset? @relation(fields: [presetId], references: [id], onDelete: SetNull)
  title                     String
  category                  String?
  notes                     String?              @db.Text
  targetDurationSeconds     Int?
  timerMode                 String               @default("countUp")
  startedAt                 DateTime
  stoppedAt                 DateTime?
  durationSeconds           Int?
  pausedAt                  DateTime?
  accumulatedPausedSeconds  Int                  @default(0)
  completed                 Boolean              @default(false)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  sessionNotes              ActivityTimerSessionNote[]

  @@index([userId, startedAt])
  @@index([userId, stoppedAt])
}

model ActivityTimerSessionNote {
  id            String               @id @default(cuid())
  sessionId     String
  session       ActivityTimerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId        String
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  text          String               @db.Text
  recordedAt    DateTime
  offsetSeconds Int
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([sessionId, recordedAt])
  @@index([userId, recordedAt])
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
